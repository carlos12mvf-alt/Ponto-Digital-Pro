{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing role and basic info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "companyId"]
    },
    "TimeLog": {
      "title": "Time Log",
      "description": "Record of a clock-in or clock-out event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["in", "out"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "accuracy": { "type": "number" }
          }
        },
        "companyId": { "type": "string" }
      },
      "required": ["userId", "type", "timestamp", "location", "companyId"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "Invitation for a user to join a company.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "companyId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "companyId", "role", "invitedBy"]
    },
    "Project": {
      "title": "Project",
      "description": "Construction project or work site.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "companyId", "status"]
    },
    "ProjectStage": {
      "title": "Project Stage",
      "description": "A specific task or stage within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "completed": { "type": "boolean" },
        "completedBy": { "type": "string" },
        "completedByName": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" }
      },
      "required": ["projectId", "title", "completed", "companyId"]
    },
    "CompanySettings": {
      "title": "Company Settings",
      "description": "Global settings for the company, like checkout reminders.",
      "type": "object",
      "properties": {
        "checkoutReminders": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["checkoutReminders"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/timeLogs/{logId}": {
      "schema": "TimeLog",
      "description": "Clock-in and clock-out records."
    },
    "/invitations/{email}": {
      "schema": "Invitation",
      "description": "Company invitations indexed by email."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Company projects."
    },
    "/projectStages/{stageId}": {
      "schema": "ProjectStage",
      "description": "Stages for projects."
    },
    "/companySettings/{companyId}": {
      "schema": "CompanySettings",
      "description": "Global settings for the company."
    }
  }
}
